{
    "name": "michael4d45/context-logging",
    "description": "Contextual logging for Laravel applications",
    "type": "composer-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael",
            "email": "michael@example.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "composer-plugin-api": "^2.2",
        "guzzlehttp/guzzle": "^7.8|^8.0",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "psr/http-message": "^1.1|^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.7",
        "doctrine/sql-formatter": "^1.0",
        "phpunit/phpunit": "^12.5",
        "orchestra/testbench": "^10.0|^11.0",
        "sentry/sentry": "^4.0"
    },
    "suggest": {
        "doctrine/sql-formatter": "Optional; enables SQL syntax highlighting when running log:monitor",
        "sentry/sentry": "Optional; enables CONTEXT_LOG_SENTRY capture of Sentry events into context logs"
    },
    "archive": {
        "exclude": [
            "/.gitignore",
            "/.phpunit.cache/",
            "/.phpunit.result.cache",
            "/composer.lock",
            "/phpunit.xml",
            "/tests/"
        ]
    },
    "autoload": {
        "psr-4": {
            "Michael4d45\\ContextLogging\\": "src/"
        },
        "exclude-from-classmap": [
            "src/Guzzle/Generated/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Michael4d45\\ContextLogging\\Tests\\": "tests/"
        }
    },
    "extra": {
        "class": "Michael4d45\\ContextLogging\\Composer\\GuzzlePatchPlugin",
        "plugin-modifies-install-path": false,
        "laravel": {
            "providers": [
                "Michael4d45\\ContextLogging\\ContextLoggingServiceProvider"
            ],
            "aliases": {
                "Log": "Michael4d45\\ContextLogging\\Log"
            }
        }
    },
    "bin": [
        "bin/install-guzzle-patch.php"
    ],
    "config": {
        "allow-plugins": {
            "michael4d45/context-logging": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
