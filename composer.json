{
    "name": "michael4d45/context-logging",
    "description": "Contextual logging for Laravel applications",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael",
            "email": "michael@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/contracts": "^12.0",
        "illuminate/http": "^12.0"
    },
    "require-dev": {
        "doctrine/sql-formatter": "^1.0",
        "phpunit/phpunit": "^12.5",
        "orchestra/testbench": "^10.0"
    },
    "suggest": {
        "doctrine/sql-formatter": "Optional; enables SQL syntax highlighting when running log:monitor"
    },
    "autoload": {
        "psr-4": {
            "Michael4d45\\ContextLogging\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Michael4d45\\ContextLogging\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Michael4d45\\ContextLogging\\ContextLoggingServiceProvider"
            ],
            "aliases": {
                "Log": "Michael4d45\\ContextLogging\\Log"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
