{
    "name": "michael4d45/context-logging",
    "description": "Contextual logging for Laravel applications",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael",
            "email": "michael@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "Michael\\ContextLogging\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Michael\\ContextLogging\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Michael\\ContextLogging\\ContextLoggingServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
